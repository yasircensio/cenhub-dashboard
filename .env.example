# GHL integration
CENHUB_PRIVATE_INTEGRATION_TOKEN=replace_with_rotated_private_integration_token
CENHUB_LOCATION_ID=XTl96fVPBYqWgZdWkfFM

# Pipeline IDs (SunTech Nordic defaults)
CENHUB_NEW_LEADS_PIPELINE_ID=YIgoFK04OJCRlMkCIa0X
CENHUB_SALES_PIPELINE_ID=mHvsnX8pjfQMEEzAvdIx
CENHUB_AFTER_SALES_PIPELINE_ID=YrKUKuQ1HlSQ1rZpeGex
# Optional fallback when GHL search payloads omit fieldKey (prefer opportunity.bundlinje on sync)
CENHUB_PROFIT_FIELD_ID=2YAu8bEKpOUSXwfYljWT
DASHBOARD_TIMEZONE=Europe/Copenhagen

# Multi-tenant admin
DASHBOARD_ADMIN_API_KEY=replace_with_strong_random_admin_key
ACCOUNT_CONFIG_ENCRYPTION_KEY=replace_with_32_byte_hex_or_base64_key

# Database (optional — file fallback at .data/multi-tenant-store.json if unset)
DATABASE_URL=

# Rollback to live GHL reads in production (requires both vars):
# DASHBOARD_READ_SOURCE=live
# DASHBOARD_LIVE_ROLLBACK=1
DASHBOARD_CACHE_TTL_MINUTES=2

# GHL marketplace webhooks (enabled in production by default; set GHL_WEBHOOK_DISABLED=1 to turn off)
# GHL_WEBHOOK_ENABLED=1
# Process webhooks inline in the HTTP request (~2–3s). Required for production — do not use Inngest for GHL webhooks.
GHL_WEBHOOK_INLINE=1

# Facebook / Make.com (legacy Make webhook — optional fallback)
MAKE_WEBHOOK_SECRET=replace_with_strong_random_secret
META_SYSTEM_USER_TOKEN=
META_GRAPH_API_VERSION=v21.0
DEFAULT_CLIENT_ID=suntech-nordic

# Vercel KV / Upstash (Facebook metrics + dashboard cache; file fallback if unset)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Per-client dashboard access keys (optional hardening).
# 1. Set a strong random secret below and deploy.
# 2. Grab each client's accessKey/clientUrl from GET /api/clients/:id (admin).
# 3. Share the key-based URL with clients, then set REQUIRE_CLIENT_ACCESS_KEY=1.
DASHBOARD_ACCESS_KEY_SECRET=
# REQUIRE_CLIENT_ACCESS_KEY=1

# GHL SSO (marketplace app shared secret from GHL app Advanced Settings)
GHL_SSO_SHARED_SECRET=

# REQUIRED for daily GHL + Meta sync (Vercel crons). Vercel sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
