{
  "functions": {
    "api/inngest.js": {
      "maxDuration": 300
    },
    "api/meta-sync-cron.js": {
      "maxDuration": 120
    },
    "api/meta-sync-inngest.js": {
      "maxDuration": 120
    },
    "api/clients.js": {
      "maxDuration": 60
    },
    "api/clients/[...path].js": {
      "maxDuration": 60
    },
    "api/ghl-webhook.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/meta-sync-cron", "destination": "/api/sync-history?__cron=meta" },
    { "source": "/api/cron/meta-sync", "destination": "/api/sync-history?__cron=meta" },
    { "source": "/login", "destination": "/admin.html" },
    { "source": "/team", "destination": "/admin.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/sync-history/:kind", "destination": "/admin.html" },
    { "source": "/admin/:client_id", "destination": "/admin.html" },
    { "source": "/:client_id", "destination": "/client.html" }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/team",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/admin/:client_id",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/meta-sync-cron",
      "schedule": "0 4 * * *"
    }
  ]
}
