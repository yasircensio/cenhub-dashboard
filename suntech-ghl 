<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SunTech Nordic – Pipeline Dashboard</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background: #0f1117;
      color: #f0f0f0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .dashboard {
      width: 100%;
      max-width: 900px;
    }

    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
    }

    .header h1 {
      font-size: 15px;
      font-weight: 600;
      color: #888;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .last-updated {
      font-size: 12px;
      color: #555;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 16px;
    }

    .card {
      background: #16191f;
      border: 1px solid #23262e;
      border-radius: 12px;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }

    .card.primary {
      grid-column: span 3;
      background: linear-gradient(135deg, #16191f 0%, #1a1f2e 100%);
      border-color: #2a3050;
    }

    .card-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #555;
      margin-bottom: 12px;
    }

    .card-value {
      font-size: 38px;
      font-weight: 700;
      color: #f0f0f0;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .card.primary .card-value {
      font-size: 52px;
      background: linear-gradient(135deg, #ffffff 0%, #a0b4ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .card-sub {
      font-size: 12px;
      color: #555;
      margin-top: 8px;
    }

    .card-accent {
      position: absolute;
      top: 0;
      right: 0;
      width: 80px;
      height: 80px;
      border-radius: 0 12px 0 80px;
      opacity: 0.06;
    }

    .accent-blue { background: #4f6ef7; }
    .accent-green { background: #22c55e; }
    .accent-orange { background: #f97316; }
    .accent-purple { background: #a855f7; }

    .pipeline-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .loading-state, .error-state {
      text-align: center;
      padding: 48px;
      color: #555;
      font-size: 14px;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 2px solid #23262e;
      border-top-color: #4f6ef7;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 16px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .error-state { color: #ef4444; }

    .refresh-btn {
      margin-top: 12px;
      background: #23262e;
      border: 1px solid #2e3240;
      color: #888;
      font-size: 12px;
      padding: 6px 16px;
      border-radius: 6px;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
    }
    .refresh-btn:hover { background: #2a2e3a; color: #ccc; }

    .status-dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #22c55e;
      margin-right: 6px;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .currency {
      font-size: 24px;
      font-weight: 400;
      color: #555;
      margin-right: 4px;
    }
    .card.primary .currency {
      font-size: 32px;
      background: none;
      -webkit-text-fill-color: #555;
    }
  </style>
</head>
<body>

<div class="dashboard" id="dashboard">
  <div class="loading-state">
    <div class="spinner"></div>
    Henter pipeline data...
  </div>
</div>

<script>
  // ─── CONFIG ───────────────────────────────────────────────
  const API_KEY      = 'PASTE_YOUR_PRIVATE_API_KEY_HERE';
  const LOCATION_ID  = 'XTl96fVPBYqWgZdWkfFM';
  const PIPELINES    = [
    { id: 'YIgoFK04OJCRlMkCIa0X', name: 'Pipeline 1' },
    { id: 'mHvsnX8pjfQMEEzAvdIx', name: 'Pipeline 2' },
  ];
  const PROFIT_FIELD = '2YAu8bEKpOUSXwfYljWT'; // opportunity.bundlinje field ID
  // ──────────────────────────────────────────────────────────

  const fmt = n => new Intl.NumberFormat('da-DK', { minimumFractionDigits: 0 }).format(Math.round(n));

  async function fetchAllOpportunities(pipelineId) {
    let all = [];
    let startAfter = null;
    let startAfterId = null;
    let page = 0;

    while (true) {
      page++;
      let url = `https://services.leadconnectorhq.com/opportunities/search?location_id=${LOCATION_ID}&pipeline_id=${pipelineId}&limit=100&status=all`;
      if (startAfter)   url += `&startAfter=${startAfter}`;
      if (startAfterId) url += `&startAfterId=${startAfterId}`;

      const res = await fetch(url, {
        headers: {
          'Authorization': `Bearer ${API_KEY}`,
          'Version': '2021-07-28',
          'Content-Type': 'application/json'
        }
      });

      if (!res.ok) throw new Error(`API error ${res.status}: ${await res.text()}`);
      const data = await res.json();
      const opps = data.opportunities || [];
      all = all.concat(opps);

      // pagination
      const meta = data.meta || {};
      if (opps.length < 100 || !meta.startAfter) break;
      startAfter   = meta.startAfter;
      startAfterId = meta.startAfterId || null;

      if (page > 50) break; // safety cap at 5000 records
    }

    return all;
  }

  function getProfit(opp) {
    const fields = opp.customFields || [];
    const f = fields.find(cf => cf.id === PROFIT_FIELD || cf.fieldKey === `opportunity.${PROFIT_FIELD}` || cf.fieldKey === PROFIT_FIELD);
    if (f && f.value !== null && f.value !== '') return parseFloat(f.value) || 0;
    return 0;
  }

  function getMonetary(opp) {
    return parseFloat(opp.monetaryValue) || 0;
  }

  async function loadDashboard() {
    const dash = document.getElementById('dashboard');

    try {
      // Fetch both pipelines in parallel
      const results = await Promise.all(
        PIPELINES.map(p => fetchAllOpportunities(p.id).then(opps => ({ ...p, opps })))
      );

      let totalProfit = 0;
      let totalMonetary = 0;
      let totalOpps = 0;
      const pipelineStats = [];

      for (const p of results) {
        const profit   = p.opps.reduce((s, o) => s + getProfit(o), 0);
        const monetary = p.opps.reduce((s, o) => s + getMonetary(o), 0);
        totalProfit   += profit;
        totalMonetary += monetary;
        totalOpps     += p.opps.length;
        pipelineStats.push({ name: p.name, profit, monetary, count: p.opps.length });
      }

      const now = new Date().toLocaleString('da-DK', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' });

      dash.innerHTML = `
        <div class="header">
          <h1><span class="status-dot"></span>SunTech Nordic – Pipeline Overblik</h1>
          <span class="last-updated">Opdateret ${now}</span>
        </div>

        <div class="cards">
          <div class="card primary">
            <div class="card-label">Total Bundlinje (alle pipelines)</div>
            <div class="card-value"><span class="currency">DKK</span>${fmt(totalProfit)}</div>
            <div class="card-sub">${totalOpps} opportunities i alt</div>
          </div>

          <div class="card">
            <div class="card-accent accent-blue"></div>
            <div class="card-label">Total Omsætning</div>
            <div class="card-value"><span class="currency" style="font-size:16px;color:#555">DKK</span>${fmt(totalMonetary)}</div>
            <div class="card-sub">Monetary value</div>
          </div>

          <div class="card">
            <div class="card-accent accent-green"></div>
            <div class="card-label">Antal Opportunities</div>
            <div class="card-value">${totalOpps}</div>
            <div class="card-sub">På tværs af begge pipelines</div>
          </div>

          <div class="card">
            <div class="card-accent accent-orange"></div>
            <div class="card-label">Gns. Bundlinje</div>
            <div class="card-value"><span class="currency" style="font-size:16px;color:#555">DKK</span>${totalOpps > 0 ? fmt(totalProfit / totalOpps) : '0'}</div>
            <div class="card-sub">Per opportunity</div>
          </div>
        </div>

        <div class="pipeline-row">
          ${pipelineStats.map((p, i) => `
            <div class="card">
              <div class="card-accent ${i === 0 ? 'accent-blue' : 'accent-purple'}"></div>
              <div class="card-label">${p.name}</div>
              <div class="card-value" style="font-size:28px"><span class="currency" style="font-size:14px;color:#555">DKK</span>${fmt(p.profit)}</div>
              <div class="card-sub">${p.count} opp. · Omsætning DKK ${fmt(p.monetary)}</div>
            </div>
          `).join('')}
        </div>

        <div style="text-align:right;margin-top:12px">
          <button class="refresh-btn" onclick="loadDashboard()">↻ Opdater</button>
        </div>
      `;

    } catch (err) {
      dash.innerHTML = `
        <div class="error-state">
          <div>⚠️ Fejl ved hentning af data</div>
          <div style="margin-top:8px;font-size:12px;color:#666">${err.message}</div>
          <button class="refresh-btn" onclick="loadDashboard()">Prøv igen</button>
        </div>
      `;
    }
  }

  loadDashboard();

  // Auto-refresh every 5 minutes
  setInterval(loadDashboard, 5 * 60 * 1000);
</script>
</body>
</html>