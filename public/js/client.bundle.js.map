  if (isVisible('kpis', 'averageWonDealSize')) {
    cards.push(`
      <div class="card">
        <div class="card-label">Avg Won Deal Size</div>
        <div class="card-value">Dkr ${fmtCompact(kpis.averageWonDealSize)}</div>
