  if (isVisible('kpis', 'openPipelineValue')) {
    cards.push(`
      <div class="card">
        <div class="card-label">Open Pipeline Value</div>
        <div class="card-value">Dkr ${fmtCompact(kpis.openPipelineValue)}</div>
        <div class="card-sub">Monetary value of open deals</div>
      </div>
